<?xml version="1.0" encoding="UTF-8"?>
<Events>

    <!-- ============================================================
         Group Change Listener
         Fires whenever any device in the selected Sensor Monitor Group
         has a state change.  As of v1.8.0, groups are first-class Indigo
         devices (type smGroup) created via Indigo Devices > New Device.
         Pre-v1.8.0 triggers configured by group name still work — the
         plugin falls back to the JSON groups[] array when no
         groupDevice is set.
         ============================================================ -->
    <Event id="sensorGroupChange">
        <Name>Sensor Monitor: Group Changed</Name>
        <ConfigUI>
            <Field id="instructions" type="label" fontSize="small">
                <Label>Fires whenever any device in the selected group has a state change. Pick the group device (Indigo Devices > New Device > Sensor Monitor Group to create one).</Label>
            </Field>
            <Field id="groupDevice" type="menu">
                <Label>Group:</Label>
                <List class="self" filter="self.smGroup" method="getGroupDeviceList" dynamicReload="true"/>
            </Field>
            <Field id="fireOn" type="menu" defaultValue="any">
                <Label>Fire on:</Label>
                <List>
                    <Option value="any">Any change (default)</Option>
                    <Option value="activated">Any device becomes ON / OPEN / detected</Option>
                    <Option value="deactivated">Any device becomes OFF / CLOSED / clear</Option>
                </List>
            </Field>
            <Field id="fireOnHint" type="label" fontColor="darkgray" fontSize="small" alignWithControl="true">
                <Label>"Any change" fires on every state update. The directional options fire only on an onState transition.</Label>
            </Field>
            <Field id="saveBool" type="checkbox" defaultValue="false">
                <Label>Save firing device:</Label>
                <Description>Save the device that triggered this event to an Indigo variable.</Description>
            </Field>
            <Field id="saveVar" type="menu" visibleBindingId="saveBool" visibleBindingValue="true">
                <Label>Save to variable:</Label>
                <List class="indigo.variables"/>
            </Field>
            <Field id="saveType" type="menu" defaultValue="name" visibleBindingId="saveBool" visibleBindingValue="true">
                <Label>Save value:</Label>
                <List>
                    <Option value="name">Device Name</Option>
                    <Option value="id">Device ID</Option>
                </List>
            </Field>
        </ConfigUI>
    </Event>

</Events>
